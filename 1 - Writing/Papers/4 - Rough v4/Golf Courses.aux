\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:mice_density}{{1}{16}{Acreage distribution from MICE imputation (cumulative $M = 100$ per language) compared against the observed parcel density. The close overlap of all three language implementations with the observed distribution confirms that the imputation model is reproducing the structural shape of the acreage distribution rather than collapsing onto its mean}{figure.caption.2}{}}
