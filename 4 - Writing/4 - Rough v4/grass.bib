keywords = {Architecture Domestic ;  Bodies of water ;  Census ;  Econometric models ;  Economic geography ;  Golf ;  Golf courses ;  High schools ;  Housing ;  Land use ;  Models Statistical ;  Open spaces ;  Parks ;  Regression analysis ;  Size ;  Tennessee ;  Time ;  Water-supply},
language = {eng},
number = {1},
